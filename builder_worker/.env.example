# Control plane access
CP_INTERNAL_SERVICE_TOKEN=change-me
CP_CELERY_BUILDER_BASE_URL=https://api.example.com
CP_CELERY_BUILDER_SERVICE_NAME=cloudflare-builder-worker
# simulated | actual
CP_BUILD_EXECUTOR_PROVIDER=simulated
# docker | shell
CP_BUILD_COMMAND_RUNNER_PROVIDER=docker
CP_BUILD_DOCKER_IMAGE=node:20-bookworm
CP_BUILD_DOCKER_ALLOWED_IMAGES=node:20-bookworm
CP_BUILD_DOCKER_INSTALL_NETWORK=bridge
CP_BUILD_DOCKER_BUILD_NETWORK=none
CP_BUILD_DOCKER_PIDS_LIMIT=256

# Cloudflare queue access
CP_CLOUDFLARE_API_BASE_URL=https://api.cloudflare.com/client/v4
CP_CLOUDFLARE_ACCOUNT_ID=
CP_CLOUDFLARE_API_TOKEN=
CP_CLOUDFLARE_QUEUE_ID=
CP_CLOUDFLARE_PULL_BATCH_SIZE=5
CP_CLOUDFLARE_PULL_VISIBILITY_TIMEOUT_MS=30000
CP_CLOUDFLARE_PULL_POLL_INTERVAL_SECONDS=5
CP_CLOUDFLARE_PULL_MAX_ATTEMPTS=3

# Current local-dev artifact publishing path for the simulated Go executor
CP_ARTIFACT_STORE_PROVIDER=local
CP_ARTIFACT_STORE_ROOT=./.artifacts

# Required when CP_ARTIFACT_STORE_PROVIDER=r2
CP_R2_ENDPOINT_URL=
CP_R2_ACCESS_KEY_ID=
CP_R2_SECRET_ACCESS_KEY=
CP_R2_SESSION_TOKEN=
CP_R2_REGION_NAME=auto
