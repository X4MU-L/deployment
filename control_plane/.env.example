# Control plane core
CP_DATABASE_URL=sqlite+aiosqlite:///./control_plane.db
CP_INTERNAL_SERVICE_TOKEN=change-me
CP_APPS_BASE_DOMAIN=apps.example.com
CP_ROUTE_CACHE_TTL_SECONDS=30

# Auth / public URLs
CP_PUBLIC_BASE_URL=http://localhost:8000
CP_CLIENT_BASE_URL=http://localhost:3000
CP_JWT_SECRET=change-me-in-production-use-a-long-random-secret

# Background build adapter
CP_BACKGROUND_BUILDER_PROVIDER=fake-builder

# Temporary local Celery builder
CP_CELERY_BROKER_URL=sqla+sqlite:///./celery-broker.sqlite
CP_CELERY_RESULT_BACKEND=db+sqlite:///./celery-results.sqlite
CP_CELERY_BUILDER_QUEUE_NAME=fake-builder
CP_CELERY_BUILDER_SERVICE_NAME=fake-builder
CP_CELERY_BUILDER_BASE_URL=http://127.0.0.1:8000
CP_CELERY_BUILDER_ARTIFACT_BUCKET=fake-static-artifacts

# Artifact store
CP_ARTIFACT_STORE_PROVIDER=local
CP_ARTIFACT_STORE_ROOT=./.artifacts

# Cloudflare R2 (required when CP_ARTIFACT_STORE_PROVIDER=r2)
CP_R2_ENDPOINT_URL=
CP_R2_ACCESS_KEY_ID=
CP_R2_SECRET_ACCESS_KEY=
CP_R2_SESSION_TOKEN=
CP_R2_REGION_NAME=auto

# Cloudflare Queues producer / pull consumer
CP_CLOUDFLARE_API_BASE_URL=https://api.cloudflare.com/client/v4
CP_CLOUDFLARE_ACCOUNT_ID=
CP_CLOUDFLARE_API_TOKEN=
CP_CLOUDFLARE_QUEUE_NAME=build-requested
CP_CLOUDFLARE_QUEUE_ID=
CP_CLOUDFLARE_ARTIFACT_BUCKET=static-artifacts
CP_CLOUDFLARE_PULL_BATCH_SIZE=5
CP_CLOUDFLARE_PULL_VISIBILITY_TIMEOUT_MS=30000
CP_CLOUDFLARE_PULL_POLL_INTERVAL_SECONDS=5
